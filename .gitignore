!package.json
!package-lock.json
!tsconfig.json
!tsconfig.*.json
!jsconfig.json
!.eslintrc.json
!.prettierrc.json
!nest-cli.json
!vercel.json
!turbo.json
!lerna.json
!renovate.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
!manifest.json
!composer.json
!Pipfile.lock

