# ============================================================
# SECRETS & ENVIRONMENT FILES — never commit these
# ============================================================
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
.env.test
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.jks
*.keystore
*.secret
*.secrets
*credentials*
*secret*
serviceAccountKey.json
gcp-key.json
firebase-adminsdk*.json
google-credentials.json

# API keys, tokens, config with secrets
config.local.*
local_settings.py
*.token

# ============================================================
# JSON FILES
# ============================================================
*.json
